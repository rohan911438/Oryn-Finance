{
  "name": "oryn-backend",
  "version": "1.0.0",
  "description": "Backend API server for Oryn Finance prediction market platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "node src/utils/seedDatabase.js",
    "build": "echo 'No build step required for Node.js'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deploy": "npm install --production && npm start"
  },
  "keywords": [
    "prediction-market",
    "stellar",
    "soroban",
    "defi",
    "oryn"
  ],
  "author": "Oryn Finance Team",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.1",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "redis": "^4.6.12",
    "socket.io": "^4.8.3",
    "stellar-sdk": "^12.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "overrides": {
